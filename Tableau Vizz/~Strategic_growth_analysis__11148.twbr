      <aliases enabled='yes' />
      <column caption='PR' datatype='real' name='[Calculation_0766099338067977]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Calculation_0766099365273612]) / NULLIF(SUM([Calculation_0766099364626442]), 0)' />
      </column>
      <column caption='Impressions' datatype='integer' name='[Calculation_0766099364626442]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [event_type]= &quot;Impression&quot; THEN 1 ELSE 0 END' />
      </column>
      <column caption='Clicks' datatype='integer' name='[Calculation_0766099364945931]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [event_type] = &quot;Click&quot; THEN 1 ELSE 0 END' />
      </column>
      <column caption='Purchases' datatype='integer' name='[Calculation_0766099365273612]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [event_type]= &quot;Purchase&quot; THEN 1 ELSE 0 END' />
      </column>
      <column caption='Engagements' datatype='integer' name='[Calculation_0766099365523469]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [event_type] = &quot;Like&quot; OR [event_type] = &quot;Comment&quot; OR [event_type] = &quot;Share&quot; THEN 1 ELSE 0 END' />
      </column>
      <column caption='CTR' datatype='real' default-format='p0.00%' name='[Calculation_0766099365683214]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Calculation_0766099364945931]) / SUM([Calculation_0766099364626442])' />
      </column>
      <column caption='CVR' datatype='real' default-format='p0.00%' name='[Calculation_0766099365867535]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Calculation_0766099365273612]) / NULLIF(SUM([Calculation_0766099364945931]), 0)' />
      </column>
      <column caption='gender match' datatype='string' name='[Calculation_0766099366105104]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [target_gender] = [user_gender] OR [target_gender] = &quot;All&quot; THEN &quot;Match&quot; ELSE &quot;Mismatch&quot; END' />
      </column>
      <column caption='Age Match' datatype='string' name='[Calculation_0766099366227985]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [target_age_group] = [age_group] OR [target_age_group] = &quot;All&quot; THEN &quot;Match&quot; ELSE &quot;Mismatch&quot; END' />
      </column>
      <column caption='Interest Match' datatype='string' name='[Calculation_0766099375177746]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [target_interests] = [interests] THEN &quot;Match&quot; ELSE &quot;Mismatch&quot; END' />
      </column>
      <column caption='Full targetting match' datatype='string' name='[Calculation_0766099375325203]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_0766099366105104] = &quot;Match&quot; AND [Calculation_0766099366227985] = &quot;Match&quot; AND [Calculation_0766099375177746] = &quot;Match&quot;&#13;&#10;THEN &quot;Fully Matched&quot;&#13;&#10;ELSEIF [Calculation_0766099366105104] = &quot;Mismatch&quot; AND [Calculation_0766099366227985] = &quot;Mismatch&quot; AND [Calculation_0766099375177746] = &quot;Mismatch&quot;&#13;&#10;THEN &quot;Fully Mismatched&quot;&#13;&#10;ELSE &quot;Partially Matched&quot;&#13;&#10;END' />
      </column>
      <column caption='Budget per Event' datatype='real' name='[Calculation_0766099375603732]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[total_budget] / {FIXED [campaign_id] : COUNTD([event_id])}' />
      </column>
      <column caption='Wasted Budget Flag' datatype='real' name='[Calculation_0766099375820821]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Calculation_0766099366105104] = &quot;Mismatch&quot; AND [Calculation_0766099366227985] = &quot;Mismatch&quot; THEN [Calculation_0766099375603732] ELSE 0 END' />
      </column>
      <column caption='Month-Year' datatype='datetime' name='[Calculation_0766099375976470]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='DATETRUNC(&apos;month&apos;, [timestamp])' />
      </column>
      <column caption='Funnel Order' datatype='integer' name='[Calculation_0766099376074775]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='CASE [event_type]&#13;&#10;  WHEN &quot;Impression&quot; THEN 1&#13;&#10;  WHEN &quot;Click&quot; THEN 2&#13;&#10;  WHEN &quot;Like&quot; THEN 3&#13;&#10;  WHEN &quot;Comment&quot; THEN 4&#13;&#10;  WHEN &quot;Share&quot; THEN 5&#13;&#10;  WHEN &quot;Purchase&quot; THEN 6&#13;&#10;END' />
      </column>
      <column caption='Count' datatype='integer' name='[Calculation_0766099382628376]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='1' />
      </column>
      <column caption='Gender Mismatch Rate' datatype='real' name='[Calculation_0766099624890397]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT(IF [target_gender] != [user_gender] AND [target_gender] != &apos;All&apos; THEN [event_id] END)&#13;&#10;/&#13;&#10;COUNT(IF [target_gender] != &apos;All&apos; THEN [event_id] END)' />
      </column>
      <column caption='Wasted Impression Rate' datatype='real' name='[Calculation_0766099633659934]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT(IF [event_type] = &apos;Impression&apos; AND [target_gender] != [user_gender] THEN [event_id] END)&#13;&#10;/&#13;&#10;COUNT(IF [event_type] = &apos;Impression&apos; THEN [event_id] END)' />
      </column>
      <column caption='Age Targetting Acuracy' datatype='real' name='[Calculation_0766099634040863]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT(IF [target_age_group] = [age_group] OR [target_age_group] = &apos;All&apos; THEN [event_id] END)&#13;&#10;/&#13;&#10;COUNT([event_id])' />
      </column>
      <column caption='Gender Match Flag' datatype='integer' name='[Calculation_0766099680575520]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [target_gender] = [user_gender] THEN 1 ELSE 0 END' />
      </column>
      <column caption='Gender Match Rate' datatype='real' name='[Gender Match Flag (copy)_0766099680739361]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([Calculation_0766099680575520])' />
      </column>
