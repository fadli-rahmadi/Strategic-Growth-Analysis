    <worksheet name='Monthly Trend CTR vs CVR'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontsize='11'>&lt;Sheet Name&gt;</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='strategic_growth_insights_cleaned' name='federated.09r43xu1sfupr118a4jea1vygcn6' />
          </datasources>
          <datasource-dependencies datasource='federated.09r43xu1sfupr118a4jea1vygcn6'>
            <column caption='Impressions' datatype='integer' name='[Calculation_0766099364626442]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [event_type]= &quot;Impression&quot; THEN 1 ELSE 0 END' />
            </column>
            <column caption='Clicks' datatype='integer' name='[Calculation_0766099364945931]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [event_type] = &quot;Click&quot; THEN 1 ELSE 0 END' />
            </column>
            <column caption='Purchases' datatype='integer' name='[Calculation_0766099365273612]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [event_type]= &quot;Purchase&quot; THEN 1 ELSE 0 END' />
            </column>
            <column caption='CTR' datatype='real' default-format='p0.00%' name='[Calculation_0766099365683214]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([Calculation_0766099364945931]) / SUM([Calculation_0766099364626442])' />
            </column>
            <column caption='CVR' datatype='real' default-format='p0.00%' name='[Calculation_0766099365867535]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([Calculation_0766099365273612]) / NULLIF(SUM([Calculation_0766099364945931]), 0)' />
            </column>
            <column caption='Month-Year' datatype='datetime' name='[Calculation_0766099375976470]' role='dimension' type='ordinal'>
              <calculation class='tableau' formula='DATETRUNC(&apos;month&apos;, [timestamp])' />
            </column>
            <column caption='Ad Platform' datatype='string' name='[ad_platform]' role='dimension' type='nominal' />
            <column caption='Event Type' datatype='string' name='[event_type]' role='dimension' type='nominal' />
            <column-instance column='[ad_platform]' derivation='None' name='[none:ad_platform:nk]' pivot='key' type='nominal' />
            <column-instance column='[event_type]' derivation='None' name='[none:event_type:nk]' pivot='key' type='nominal' />
            <column-instance column='[user_gender]' derivation='None' name='[none:user_gender:nk]' pivot='key' type='nominal' />
            <column caption='Timestamp' datatype='datetime' name='[timestamp]' role='dimension' type='ordinal' />
            <column-instance column='[Calculation_0766099375976470]' derivation='Month-Trunc' name='[tmn:Calculation_0766099375976470:qk]' pivot='key' type='quantitative' />
            <column caption='User Gender' datatype='string' name='[user_gender]' role='dimension' type='nominal' />
            <column-instance column='[Calculation_0766099365683214]' derivation='User' name='[usr:Calculation_0766099365683214:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_0766099365867535]' derivation='User' name='[usr:Calculation_0766099365867535:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <filter class='categorical' column='[federated.09r43xu1sfupr118a4jea1vygcn6].[none:ad_platform:nk]' filter-group='4'>
